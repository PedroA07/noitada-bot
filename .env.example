# ================================================
# NOITADA BOT — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ================================================

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CLIENT_ID=

# Supabase — use a SERVICE ROLE KEY (não a anon key!)
# Encontre em: Supabase > Settings > API > service_role
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do site (ex: https://seu-site.vercel.app)
# Usado para gerar a imagem estilizada do card no /spawn
WEB_URL=
